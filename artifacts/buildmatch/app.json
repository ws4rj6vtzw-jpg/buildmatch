{
  "expo": {
    "name": "BuildMatch",
    "slug": "buildmatch",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "buildmatch",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0F12"
    },
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.buildmatch.ios",
      "buildNumber": "7",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "BuildMatch uses your photo library so you can set a profile picture.",
        "NSCameraUsageDescription": "BuildMatch uses your camera so you can take a profile photo.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock your BuildMatch account.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.512051311397-djuhcjpnui7img3cbflctefarlrq1ot4"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "app.buildmatch.android",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "./plugins/withFirebaseStaticFrameworks",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "expo-updates",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "BuildMatch uses your photo library so you can set a profile picture.",
          "cameraPermission": "BuildMatch uses your camera so you can take a profile photo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0f172a"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to quickly unlock your BuildMatch account."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/c675e172-afb6-48f4-b860-d1026e5ad61a",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "c675e172-afb6-48f4-b860-d1026e5ad61a"
      }
    },
    "owner": "gordonwilson"
  }
}
